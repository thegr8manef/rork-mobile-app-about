    "prebuild:restore": "node scripts/restore-android.js",
    "android:dev": "cross-env APP_ENV=development expo run:android",
    "android:dev:gradle": "cross-env APP_ENV=development ./android/gradlew -p android assembleDebug",
    "android:release:dev": "cross-env APP_ENV=development ./android/gradlew -p android generateCodegenArtifactsFromSchema assembleRelease",
    "android:release": "cross-env APP_ENV=production ./android/gradlew -p android generateCodegenArtifactsFromSchema assembleRelease",
    "android:install:release": "cross-env APP_ENV=production ./android/gradlew -p android installRelease",
    "android:release:aab": "cross-env APP_ENV=production ./android/gradlew -p android generateCodegenArtifactsFromSchema bundleRelease",
    "android:prod": "cross-env APP_ENV=production expo run:android",
    "android:logs": "adb logcat *:S ReactNative:V ReactNativeJS:V",
    "eas:release:aab": "npx eas build --platform android --local --profile production",
    "eas:release:apk": "npx eas build --platform android --local --profile production-apk",
    "eas:preview:release": "npx eas build --platform android --local --profile preview-release",
    "android:preview": "rm -rf node_modules/.cache/metro && cd android && rm -rf app/.cxx && rm -rf app/build && ./gradlew clean && ./gradlew assemblePreviewRelease"
