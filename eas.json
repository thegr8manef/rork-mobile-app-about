{
  "cli": {
    "version": ">= 10.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "NPM_CONFIG_INCLUDE_OPTIONAL": "true",
        "NPM_CONFIG_OPTIONAL": "true"
      },
      "android": { "buildType": "apk" }
    },
    "production": {
      "channel": "production",
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      }
    },
    "production-apk": {
      "channel": "production",
      "env": {
        "APP_ENV": "production",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview-release": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "APP_ENV": "development",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "NPM_CONFIG_INCLUDE_OPTIONAL": "true",
        "NPM_CONFIG_OPTIONAL": "true"
      },
      "android": {
        "gradleCommand": ":app:assemblePreviewRelease",
        "buildType": "apk"
      }
    }
  }
}